# Copy this file to .env and fill in your keys.
# .env is gitignored — your keys never leave your machine.

# ── Google Gemini API (Nano Banana image generation) ──
# Get yours free at https://aistudio.google.com/apikey
# Used by: skills/gemini-image-designer/
GEMINI_API_KEY=

# Gemini model used for image generation.
# Default is gemini-2.5-flash-image (Nano Banana). Override only if you know what you're doing.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
